# =============================================================================
# Career Autopilot — Environment Variables
# Copy this file to .env.local and fill in all values before running locally.
# Never commit .env.local to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=

# -----------------------------------------------------------------------------
# Clerk Authentication
# https://clerk.com/docs/quickstarts/nextjs
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
CLERK_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Database — Neon Serverless Postgres
# https://neon.tech/docs/guides/nextjs
# -----------------------------------------------------------------------------
DATABASE_URL=

# -----------------------------------------------------------------------------
# Upstash Redis
# https://upstash.com/docs/redis/quickstarts/nextjs
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------------------------------
# Upstash QStash (background job queue)
# https://upstash.com/docs/qstash/quickstarts/nextjs
# -----------------------------------------------------------------------------
QSTASH_URL=
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# -----------------------------------------------------------------------------
# Supabase Storage
# https://supabase.com/docs/guides/storage
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Groq (primary AI — free, extremely fast)
# https://console.groq.com → API Keys
# -----------------------------------------------------------------------------
GROQ_API_KEY=

# -----------------------------------------------------------------------------
# Anthropic Claude (fallback AI)
# https://docs.anthropic.com/en/api/getting-started
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Resend (transactional email)
# https://resend.com/docs/send-with-nextjs
# -----------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@careerautopilot.in

# -----------------------------------------------------------------------------
# Razorpay (payments)
# https://razorpay.com/docs/payments/server-integration/nodejs/
# -----------------------------------------------------------------------------
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# -----------------------------------------------------------------------------
# GitHub OAuth & API
# Used for portfolio deployment and repo analysis
# -----------------------------------------------------------------------------
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_APP_TOKEN=

# -----------------------------------------------------------------------------
# LinkedIn OAuth & API
# Used for direct post publishing (Pro feature)
# -----------------------------------------------------------------------------
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Vercel API (portfolio deployment target)
# https://vercel.com/docs/rest-api
# -----------------------------------------------------------------------------
VERCEL_API_TOKEN=
VERCEL_TEAM_ID=

# -----------------------------------------------------------------------------
# Netlify API (portfolio deployment target)
# https://docs.netlify.com/api/get-started/
# -----------------------------------------------------------------------------
NETLIFY_ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# Render API (portfolio deployment target)
# https://render.com/docs/api
# -----------------------------------------------------------------------------
RENDER_API_KEY=

# -----------------------------------------------------------------------------
# Railway API (Docker deployment target)
# https://docs.railway.app/reference/public-api
# -----------------------------------------------------------------------------
RAILWAY_API_TOKEN=

# -----------------------------------------------------------------------------
# Sentry (error tracking)
# https://docs.sentry.io/platforms/javascript/guides/nextjs/
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# -----------------------------------------------------------------------------
# Encryption
# Used to encrypt stored OAuth tokens at rest
# Generate with: openssl rand -base64 32
# -----------------------------------------------------------------------------
ENCRYPTION_KEY=
